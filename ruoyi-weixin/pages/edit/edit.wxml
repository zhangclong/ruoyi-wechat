<view class="container">
  <view class="form-container">
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{nickName}}" bindinput="onNickNameInput" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="手机号不可修改" value="{{phonenumber}}" disabled />
    </view>

    <view class="form-item">
      <text class="label">头像</text>
      <view class="avatar-container">
        <image class="avatar" src="{{avatar || '/pages/index/user-unlogin.png'}}" mode="aspectFill"></image>
        <button class="avatar-button" bindtap="chooseAvatar">更换头像</button>
      </view>
    </view>

    <button class="save-button" bindtap="handleSave">保存</button>
  </view>
</view>
