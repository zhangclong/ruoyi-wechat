<view class="container">
  <view class="form-container">
    <view class="title">会员注册</view>

    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{nickName}}" bindinput="onNickNameInput" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phonenumber}}" bindinput="onPhoneInput" maxlength="11" />
    </view>

    <view class="form-item">
      <text class="label">头像</text>
      <view class="avatar-container">
        <image class="avatar" src="{{avatar || '/pages/index/user-unlogin.png'}}" mode="aspectFill"></image>
        <button class="avatar-button" bindtap="chooseAvatar">选择头像</button>
      </view>
    </view>

    <button class="register-button" bindtap="handleRegister">注册</button>

    <view class="footer">
      <text class="link" bindtap="goToLogin">已有账号？去登录</text>
    </view>
  </view>
</view>
