.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.phone {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  padding: 40rpx;
  margin-top: -40rpx;
}

.section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.edit-button {
  width: 100%;
  height: 88rpx;
  background-color: #667eea;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  line-height: 88rpx;
  margin-bottom: 20rpx;
}

.logout-button {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  color: #666;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 32rpx;
  line-height: 88rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  background-color: #fff;
  border-radius: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 300rpx;
  height: 88rpx;
  background-color: #667eea;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  line-height: 88rpx;
  margin: 0 auto;
}
