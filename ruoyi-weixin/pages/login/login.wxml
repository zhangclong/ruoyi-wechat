<view class="container">
  <view class="form-container">
    <view class="title">会员登录</view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phonenumber}}" bindinput="onPhoneInput" maxlength="11" />
    </view>

    <button class="login-button" bindtap="handleLogin">登录</button>

    <view class="footer">
      <text class="link" bindtap="goToRegister">还没有账号？去注册</text>
    </view>
  </view>
</view>
