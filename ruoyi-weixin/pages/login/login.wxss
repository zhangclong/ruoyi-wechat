.container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-container {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-top: 120rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 60rpx;
  color: #333;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.login-button {
  width: 100%;
  height: 88rpx;
  background-color: #576b95;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  line-height: 88rpx;
  margin-top: 40rpx;
}

.footer {
  text-align: center;
  margin-top: 40rpx;
}

.link {
  color: #07c160;
  font-size: 28rpx;
}
