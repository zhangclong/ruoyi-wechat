<!--index.wxml-->
<navigation-bar title="会员小程序" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <view class="welcome">
      <text class="welcome-title">欢迎使用会员系统</text>
      <text class="welcome-desc">请先注册或登录</text>
    </view>

    <view class="actions">
      <navigator url="/pages/register/register" class="action-button primary">
        <text>注册</text>
      </navigator>
      <navigator url="/pages/login/login" class="action-button secondary">
        <text>登录</text>
      </navigator>
    </view>

    <view class="features">
      <view class="feature-item">
        <text class="feature-icon">📝</text>
        <text class="feature-title">快速注册</text>
        <text class="feature-desc">仅需手机号和昵称即可注册</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🔐</text>
        <text class="feature-title">便捷登录</text>
        <text class="feature-desc">手机号一键登录</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">👤</text>
        <text class="feature-title">个人中心</text>
        <text class="feature-desc">查看和编辑个人信息</text>
      </view>
    </view>
  </view>
</scroll-view>
